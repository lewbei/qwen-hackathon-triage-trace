# Qwen Cloud (OpenAI-compatible)
# Default endpoint for token-plan keys in ap-southeast-1.
QWEN_API_KEY=your-qwen-cloud-api-key
QWEN_BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.7-plus
QWEN_EXTRACTION_MODEL=qwen3.6-flash
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank
QWEN_RERANK_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# Optional: route chat and embeddings to different OpenAI-compatible endpoints/keys.
# If unset, the QWEN_API_KEY / QWEN_BASE_URL values above are used.
# QWEN_CHAT_API_KEY=
# QWEN_CHAT_BASE_URL=
# QWEN_EMBEDDING_API_KEY=
# QWEN_EMBEDDING_BASE_URL=

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/triagetrace
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/triagetrace

# Runtime
APP_ENV=development
LOG_LEVEL=info
MEMORY_TOKEN_BUDGET=800
USE_LLM_POISON_CHECK=0
DEFAULT_TENANT=default
DEMO_SECRET=change-me-in-production

# Test gates (0 = disabled, 1 = enabled)
LIVE_QWEN_TEST=0
