# Qwen Cloud (OpenAI-compatible)
# Free-tier / hackathon keys must use the international endpoint.
QWEN_API_KEY=your-qwen-cloud-api-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.7-plus
QWEN_EXTRACTION_MODEL=qwen3.6-flash
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/triagetrace
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/triagetrace

# Runtime
APP_ENV=development
LOG_LEVEL=info
MEMORY_TOKEN_BUDGET=800
DEFAULT_TENANT=default

# Test gates (0 = disabled, 1 = enabled)
LIVE_QWEN_TEST=0
